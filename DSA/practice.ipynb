   "source": [
    "def SelectionSort(nums):\n",
    "    n=len(nums)\n",
    "    for i in range(0,n-1):\n",
    "        min=i\n",
    "        for j in range(i+1,n):\n",
    "            if nums[j]<nums[min]:\n",
    "                min=j\n",
    "        nums[i],nums[min]=nums[min],nums[i]\n",
    "    return nums"
   ]
  }
